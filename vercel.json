{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/sitemap.xml", "dest": "/sitemaps/sitemap.xml", "status": 301 },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/([^.]+)", "dest": "/index.html" }
  ]
}
